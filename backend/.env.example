# Copy this file to `.env` and fill in values for production.

# LLM provider. Options: mock, openai, anthropic
LLM_PROVIDER=mock

# API keys for providers. Only required if LLM_PROVIDER is not `mock`.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Port for the HTTP server. Defaults to 3001.
PORT=3001

# Database file path. Defaults to `database.sqlite` in project root.
DB_FILE=database.sqlite